//------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: mohf_bpd.bt
//   Authors: Sten + Claude
//   Version: 0.7.0
//   Purpose: Medal of Honor Frontline - BPD Level Geometry
//  Category: Game
// File Mask: *.bpd
//  ID Bytes: 09 00 00 00
//   History:
//     0.7.0  2026-05-27  Full rewrite: clean structure, correct field names,
//                        vertex runtime-pointer bytes documented, CDB companion noted.
//     0.6.0  2026-05-25  SmallVB index buffer purpose confirmed.
//     0.5.0  2026-05-25  Diffuse texture mapping solved via SubMesh centroid lookup.
//     0.4.0  2026-05-24  All particle blocks decoded.
//     0.3.1  2026-05-23  BSP plane pool decoded.
//     0.2.0  2026-05-22  MainVB Vertex24 decoded; SubMesh + SmallVB.
//     0.1.0  2026-05-22  Initial.
//
// ── OVERVIEW ─────────────────────────────────────────────────────────────────
//
//  BPD = Binary Polytope Data.
//  Contains RENDER geometry for floor and ceiling surfaces only.
//  Walls are in the companion CDB file (Collision Data Block).
//
//  Companion files (same base name, different extension):
//    _P.bpd  → this file (render geometry)
//    _P.psp  → physics/pathfinding data
//    _C.cdb  → collision geometry WITH walls (world-space float3 verts, 3D)
//
//  Coordinate system: X=right, Y=forward, Z=up (MOHF world space)
//
// ── FILE LAYOUT ──────────────────────────────────────────────────────────────
//
//  [0x00..0x57]  Header          88B  (11 × offset/count pairs)
//  [SHPX blocks] embedded        78 lightmap texture blocks (SHPX format)
//  [ShpxPtrTbl]  78 × 4B        abs file offsets to each embedded SHPX block
//  [Centroids]   79 × 12B       float3 centroid positions (one per SubMesh polygon group)
//  [SubMeshTbl]  20 × 12B       diffuse texture assignment per polygon group
//  [IdxBuf]      6188 × 2B      triangle indices: 1018 (SubMesh strips) + 5170 (MainVB strip)
//  [MainVB]      1364 × 24B     render vertices (pos + lightmap UV + runtime bytes)
//  [BspPlanes]   204 × 16B      float4 BSP split planes (Nx,Ny,Nz,D)
//  [BspNodes]    17 × 48B       AABB BSP leaf nodes
//  [NamePool]    252B            null-terminated particle emitter name strings
//  [EmitterTbl]  15 × 8B        particle emitter instances (name ptr + data ptr)
//  [EffectTbl]   244 × 8B       particle effect texture lookup
//  [EffectDefs]  variable        244 particle effect definitions
//  [EmitTypes]   5 × 124B       particle emitter type definitions
//  [Particles]   variable        543 particle instance records (variable-size each)
//
// ── VERTEX FORMAT (24B stride) ───────────────────────────────────────────────
//
//  [+00..+0B]  float3    XYZ           world-space position (meters)
//  [+0C..+13]  uint32[3] RuntimePtrs   patched by engine at load time, ignore in file
//                                       (values are 0 in file; engine writes vtx buffer ptrs)
//  [+14..+14]  uint8     LM_U          lightmap atlas U (0..255 = 0.0..1.0)
//  [+15..+15]  uint8     LM_V          lightmap atlas V (0..255 = 0.0..1.0)
//  [+16..+17]  uint16    LM_TexIndex   index into ShpxPtrTbl (all 1364 verts = 7 for 1_1_P)
//
//  NOTE: No diffuse UV in vertex. Diffuse assigned per-polygon via SubMesh centroid lookup.
//  NOTE: lm_u 0..254, lm_v 115..163 (narrow band within single 32×32 lightmap atlas).
//
// ── DIFFUSE TEXTURE ASSIGNMENT ───────────────────────────────────────────────
//
//  SubMesh table has 20 entries. Each entry covers a group of polygons sharing a texture.
//  To find a polygon's diffuse texture:
//    1. Compute polygon centroid (average of 3 vertex positions)
//    2. Find nearest Centroid entry → that SubMesh's TexIdx is the diffuse texture
//
//  TexIdx is a global index across all level CPT files:
//    c0: 0-53   c1: 54-69   c2: 70-109   c3: 110-130
//    c4: 131-144   c5: 145-185   c6: 186-225
//
// ── INDEX BUFFER ─────────────────────────────────────────────────────────────
//
//  Single contiguous buffer from SubMeshTbl-end to MainVB-start.
//  First 1018 entries: triangle strip indices for SubMesh detail geometry.
//  Remaining 5170 entries: MainVB triangle strip (no 0xFFFF sentinels).
//  Strip winding: degenerate pairs (idx[i]==idx[i+1] or idx[i+1]==idx[i+2]) flip winding.
//
// ── BSP NODES ────────────────────────────────────────────────────────────────
//
//  Each node has a bounding box and up to 3 child references.
//  Child1: 6 planes from BspPlanes (AABB = 6 half-space planes)
//  Child2: vertex range (2 × uint32)
//  Child3: usually empty
//
//------------------------------------------------

LittleEndian();
OutputPaneClear();

// ── Header ───────────────────────────────────────────────────────────────────

typedef struct {
    uint32  Signature       <format=hex, comment="= 0x09">;
    uint32  FileSize;
    uint32  SubMeshOff      <format=hex>;
    uint32  SubMeshCount;                   // = 20
    uint32  MainVBOff       <format=hex>;
    uint32  MainVBCount;                    // vertex count (= 1364 for 1_1_P)
    uint32  ShpxPtrTblOff   <format=hex>;
    uint32  ShpxCount;                      // = 78 embedded lightmap SHPX blocks
    uint32  ParticleInstOff <format=hex, comment="Block5: particle instance records">;
    uint32  ParticleInstCnt;                // = 543
    uint32  EffectDefOff    <format=hex, comment="Block6: particle effect definitions">;
    uint32  EffectDefCnt;                   // = 244
    uint32  EmitTypeOff     <format=hex, comment="Block7: emitter type definitions">;
    uint32  EmitTypeCnt;                    // = 5
    uint32  BspNodeOff      <format=hex, comment="Block8: AABB BSP leaf nodes">;
    uint32  BspNodeCnt;                     // = 17
    uint32  EmitterInstOff  <format=hex, comment="Block9: emitter instance table">;
    uint32  EmitterInstCnt;                 // = 15
    uint32  EffectLookupOff <format=hex, comment="BlockA: effect texture lookup">;
    uint32  EffectLookupCnt;                // = 244
    uint32  Unk_B_Off       <format=hex>;
    uint32  Unk_B_Cnt;                      // = 244 (same count as EffectLookup)
} BPD_HEADER;

BPD_HEADER Header;

// ── SHPX Pointer Table ───────────────────────────────────────────────────────

FSeek(Header.ShpxPtrTblOff);

typedef struct {
    uint32  AbsOffset <format=hex, comment="file offset to embedded SHPX block">;
} SHPX_PTR <read=ReadShpxPtr>;

string ReadShpxPtr(SHPX_PTR& p) {
    string s; SPrintf(s, "0x%X", p.AbsOffset); return s;
}

SHPX_PTR ShpxPtrTbl[Header.ShpxCount];  // 78 lightmap texture offsets

// ── Centroid Array ───────────────────────────────────────────────────────────

typedef struct { float X, Y, Z; } VEC3 <read=ReadVec3>;
string ReadVec3(VEC3& v) {
    string s; SPrintf(s, "(%.1f, %.1f, %.1f)", v.X, v.Y, v.Z); return s;
}

local quad centroid_start = FTell();
local quad centroid_count = (Header.SubMeshOff - centroid_start) / 12;
VEC3 Centroids[centroid_count];  // 79 polygon-group centroid positions

// ── SubMesh Table ────────────────────────────────────────────────────────────

FSeek(Header.SubMeshOff);

typedef struct {
    uint32  TexIdx;         // global diffuse texture index (across all level CPT files)
    uint32  CentroidCount;  // number of centroid points for this group
    uint32  CentroidPtr <format=hex, comment="abs offset into Centroids array">;
} SUBMESH <read=ReadSubMesh>;

string ReadSubMesh(SUBMESH& s) {
    string r; SPrintf(r, "tex=%d  centroids=%d", s.TexIdx, s.CentroidCount); return r;
}

SUBMESH SubMeshTbl[Header.SubMeshCount];  // 20 diffuse material groups

// ── Index Buffer ─────────────────────────────────────────────────────────────

local quad ib_start = FTell();
local quad ib_count = (Header.MainVBOff - ib_start) / 2;

uint16 IdxBuf[ib_count];
// First 1018: SubMesh detail strip indices (max index < 248)
// Remaining 5170: MainVB triangle strip (degenerate-pair restarts, no 0xFFFF)

// ── Main Vertex Buffer ───────────────────────────────────────────────────────

FSeek(Header.MainVBOff);

typedef struct {
    float   X, Y, Z;           // world-space position
    uint32  RuntimePtr0;        // = 0 in file; engine patches at load
    uint32  RuntimePtr1;        // = 0 in file; engine patches at load
    uint32  RuntimePtr2;        // = 0 in file; engine patches at load
    ubyte   LM_U;               // lightmap U coordinate (0=0.0 .. 255=1.0)
    ubyte   LM_V;               // lightmap V coordinate (0=0.0 .. 255=1.0)
    uint16  LM_TexIndex;        // index into ShpxPtrTbl (= 7 for all verts in 1_1_P)
} VERTEX <read=ReadVertex, size=24>;

string ReadVertex(VERTEX& v) {
    string s;
    SPrintf(s, "(%.1f, %.1f, %.1f)  lm[%d]=(%d,%d)",
            v.X, v.Y, v.Z, v.LM_TexIndex, v.LM_U, v.LM_V);
    return s;
}

VERTEX MainVB[Header.MainVBCount];

// ── BSP Plane Pool ───────────────────────────────────────────────────────────

local quad bspplane_start = FTell();
local quad bspplane_count = (Header.BspNodeOff - bspplane_start) / 16;

typedef struct {
    float Nx, Ny, Nz;   // plane normal (unit vector)
    float D;             // plane distance: dot(pos, N) == D
} BSP_PLANE <read=ReadPlane>;

string ReadPlane(BSP_PLANE& p) {
    string s;
    SPrintf(s, "n=(%.3f,%.3f,%.3f) d=%.3f", p.Nx, p.Ny, p.Nz, p.D);
    return s;
}

BSP_PLANE BspPlanes[bspplane_count];  // 204 BSP split planes

// ── BSP Nodes ────────────────────────────────────────────────────────────────

FSeek(Header.BspNodeOff);

typedef struct {
    float   BBoxMinX, BBoxMinY, BBoxMinZ;
    float   BBoxMaxX, BBoxMaxY, BBoxMaxZ;
    uint32  PlaneCount;                     // = 6 (one AABB = 6 half-space planes)
    uint32  PlaneOff    <format=hex, comment="abs offset into BspPlanes (6 × BSP_PLANE)">;
    uint32  VtxRngCount;                    // = 2 (vertex range: first, count)
    uint32  VtxRngOff   <format=hex, comment="abs offset to uint32[2] vertex range">;
    uint32  Unk3Count;
    uint32  Unk3Off     <format=hex>;
} BSP_NODE <read=ReadBspNode, size=48>;

string ReadBspNode(BSP_NODE& n) {
    string s;
    SPrintf(s, "bbox=(%.0f..%.0f, %.0f..%.0f, %.0f..%.0f)",
            n.BBoxMinX, n.BBoxMaxX, n.BBoxMinY, n.BBoxMaxY, n.BBoxMinZ, n.BBoxMaxZ);
    return s;
}

BSP_NODE BspNodes[Header.BspNodeCnt];

// ── Emitter Name Pool ────────────────────────────────────────────────────────

local quad namepool_start = FTell();
local quad namepool_size  = Header.EmitterInstOff - namepool_start;
byte NamePool[namepool_size];
// Null-terminated strings: "DmitriParticle01".."DmitriParticle16", "Explosion05" etc.

// ── Emitter Instance Table ───────────────────────────────────────────────────

FSeek(Header.EmitterInstOff);

typedef struct {
    uint32  NamePtr <format=hex, comment="abs offset into NamePool">;
    uint32  DataPtr <format=hex, comment="abs offset into ParticleInst data">;
} EMITTER_INST <read=ReadEmitterInst>;

string ReadEmitterInst(EMITTER_INST& e) {
    string s; SPrintf(s, "name@0x%X  data@0x%X", e.NamePtr, e.DataPtr); return s;
}

EMITTER_INST EmitterInstTbl[Header.EmitterInstCnt];  // 15 named emitter instances

// ── Effect Texture Lookup ────────────────────────────────────────────────────

FSeek(Header.EffectLookupOff);

typedef struct {
    uint32  NamePtr <format=hex, comment="abs offset to effect texture name string">;
    uint32  DefPtr  <format=hex, comment="abs offset into EffectDefs">;
} EFFECT_LOOKUP <read=ReadEffectLookup>;

string ReadEffectLookup(EFFECT_LOOKUP& e) {
    string s; SPrintf(s, "name@0x%X  def@0x%X", e.NamePtr, e.DefPtr); return s;
}

EFFECT_LOOKUP EffectLookupTbl[Header.EffectLookupCnt];  // 244 effect name→def mappings

// ── Effect Definitions (variable-size blob) ──────────────────────────────────

FSeek(Header.EffectDefOff);
local quad effectdef_size = Header.EmitTypeOff - Header.EffectDefOff;
byte EffectDefs[effectdef_size];
// 244 variable-size records. Each: hash(4B) + blend_mode(4B) + color + float params.

// ── Emitter Type Definitions ─────────────────────────────────────────────────

FSeek(Header.EmitTypeOff);
typedef struct { byte Data[124]; } EMITTER_TYPE;
EMITTER_TYPE EmitterTypes[Header.EmitTypeCnt];  // 5 emitter type defs × 124B

// ── Particle Instance Data (variable-size blob) ──────────────────────────────

FSeek(Header.ParticleInstOff);
local quad particleinst_size = Header.FileSize - Header.ParticleInstOff;
byte ParticleInstData[particleinst_size];
// 543 variable-size records. Contains world positions, velocities, timing.
// Also contains the 244-name string pool referenced by EffectLookupTbl.NamePtr.

// ── Summary ──────────────────────────────────────────────────────────────────

Printf("=== BPD Summary ===\n");
Printf("File:          %d bytes\n", Header.FileSize);
Printf("\nRender geometry:\n");
Printf("  Centroids:   %d float3\n", centroid_count);
Printf("  SubMeshes:   %d  (diffuse material groups)\n", Header.SubMeshCount);
Printf("  IdxBuf:      %d uint16  (1018 SubMesh + 5170 MainVB strip)\n", ib_count);
Printf("  MainVB:      %d vertices × 24B\n", Header.MainVBCount);
Printf("  BSP planes:  %d float4\n", bspplane_count);
Printf("  BSP nodes:   %d\n", Header.BspNodeCnt);
Printf("  Lightmaps:   %d SHPX blocks\n", Header.ShpxCount);
Printf("\nParticle system:\n");
Printf("  Emitter instances:  %d\n", Header.EmitterInstCnt);
Printf("  Effect lookups:     %d\n", Header.EffectLookupCnt);
Printf("  Emitter type defs:  %d × 124B\n", Header.EmitTypeCnt);
Printf("  Particle instances: %d (variable-size records)\n", Header.ParticleInstCnt);
Printf("\nNOTE: No diffuse UV in vertices. Use SubMesh centroid lookup.\n");
Printf("NOTE: Walls not in BPD - see companion _C_c0.cdb for collision geometry.\n");
