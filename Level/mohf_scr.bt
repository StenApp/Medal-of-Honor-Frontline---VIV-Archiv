//------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: mohf_scr.bt
//   Authors: Sten + Claude
//   Version: 0.1.0
//   Purpose: Medal of Honor Frontline - SCR Screen Script
//  Category: Game
// File Mask: *.scr
//   History:
//     0.1.0  2026-05-27  Initial. Header confirmed.
//
// SCR = compiled UI screen layout script.
// PauseScr.scr = Pause menu screen definition.
// Contains UI widget layout, string references, controller handling.
// Strings visible: "CONTINUE", "Abort Mission?",
//   "Please reconnect the controller to controller port 1", "CHANGE", "CHOOSE"
//
// Header:
//   [00] uint32 = 16       (header size?)
//   [04] uint32 = 48       (first section offset?)
//   [08] uint32 = 21       (section count?)
//   [0C] uint32 = 0x16BC   (data size)
//   [14] uint32 = 0x16BC   (duplicate)
//   [18] uint32 = 2        (widget count?)
//   [1C] uint32 = 32
//------------------------------------------------

LittleEndian();
OutputPaneClear();

uint32  HeaderSize;     // = 16
uint32  Field_04;       // = 48
uint32  SectionCount;   // = 21
uint32  DataSize;       // = 0x16BC
uint32  Field_10;
uint32  Field_14;       // = 0x16BC (duplicate)
uint32  WidgetCount;    // = 2
uint32  Field_1C;       // = 32

byte    ScriptData[FileSize()-32] <comment="compiled UI script bytecode + string table">;

Printf("=== SCR Summary ===\n");
Printf("Section count: %d\n", SectionCount);
Printf("Data size: %d bytes\n", DataSize);
Printf("Widget count: %d\n", WidgetCount);
Printf("NOTE: Contains UI layout, string refs, Xbox controller handling.\n");
