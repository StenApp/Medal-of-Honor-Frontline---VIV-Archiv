//------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: mohf_cls.bt
//   Authors: Sten + Claude
//   Version: 0.1.0
//   Purpose: Medal of Honor Frontline - CLS Collision Shape
//  Category: Game
// File Mask: *.cls
//   History:
//     0.1.0  2026-05-27  Initial. Stride=128B confirmed, 24 bones for soldier.
//
// CLS = per-bone collision capsule/box shapes for character hitboxes.
// One entry per skeletal bone that has a collision shape.
// Filenames: soldier.cls, soldier_easy.cls, soldier_medium.cls etc.
// (difficulty affects capsule dimensions = hit registration)
//
// Entry format (128B per bone):
//   [+00]     0xCCCCCCCC  MSVC uninit marker (padding start)
//   [+04]     float RadiusX   capsule radius X
//   [+08]     float RadiusY   capsule radius Y
//   [+0C]     float RadiusZ   capsule radius Z / half-length
//   [+10..+3F] float[12]  rotation matrix (3×4 floats = 3 rows of 4)
//   [+40..+4E] float[4]   offset/translation (local bone offset)
//   [+4F]     char[48]   bone name (null-terminated, e.g. "?co_HipBShape")
//   [+70]     uint32 ShapeType  1=capsule, 2=box
//   [+74..+7F] 0xCCCCCCCC  MSVC uninit marker (padding end)
//------------------------------------------------

LittleEndian();
OutputPaneClear();

local int entry_count = FileSize() / 128;
Printf("CLS: %d collision shapes\n", entry_count);

typedef struct {
    uint32  Marker0     <format=hex, comment="0xCCCCCCCC MSVC uninit">;
    float   RadiusX;
    float   RadiusY;
    float   RadiusZ;
    float   RotMatrix[12];          // 3×4 rotation matrix
    float   Offset[4];              // local offset (x,y,z,w)
    char    BoneName[48];           // e.g. "?co_HipBShape"
    uint32  ShapeType;              // 1=capsule  2=box
    uint32  Marker1[3] <format=hex, comment="0xCCCCCCCC padding">;
} CLS_ENTRY <read=ReadEntry, size=128>;

string ReadEntry(CLS_ENTRY& e) {
    string s;
    SPrintf(s, "%s  r=(%.3f,%.3f,%.3f) type=%d",
            e.BoneName, e.RadiusX, e.RadiusY, e.RadiusZ, e.ShapeType);
    return s;
}

CLS_ENTRY Shapes[entry_count];
