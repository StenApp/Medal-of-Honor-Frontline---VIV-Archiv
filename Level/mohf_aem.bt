//------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: mohf_aem.bt
//   Authors: Sten + Claude
//   Version: 0.1.0
//   Purpose: Medal of Honor Frontline - AEM Audio Event Manager
//  Category: Game
// File Mask: *.aem
//   History:
//     0.1.0  2026-05-27  Initial. Header + 3 sections confirmed.
//
// AEM = Audio Event Manager. Maps game events to audio cues.
// Pure binary, no embedded strings.
// EventSystem.aem = global audio event routing table.
//
// Header (0x28 bytes):
//   [00] uint24 sig = 0x154541 ("AE" + version 0x15)
//   [04] uint32 field_04
//   [08] uint32 field_08
//   [0C] hi16: section_a_count=1   lo16: section_b_count=17
//   [10] uint32 = 32 (header size?)
//   [14] uint32 section_a_off = 0xB48
//   [18] uint32 section_b_off = 0xFA8
//   [1C] uint32 section_c_off = 0x1684
//   [20] uint32 = 0
//   [24] uint32 = 1
//
// Section A: 1 × 1120B  (event routing tree, nodes with 0xFFFFFFFF sentinels)
// Section B: 17 × 103B  (event handler records, ptr+count pairs)
// Section C: 80B        (event ID table, sequential uint32s)
//------------------------------------------------

LittleEndian();
OutputPaneClear();

uint32  Signature   <format=hex, comment="0x154541 = AE v0x15">;
uint32  Field_04;
uint32  Field_08;
uint16  SectionBCount;      // = 17
uint16  SectionACount;      // = 1
uint32  HeaderSize;         // = 32
uint32  SectionAOff  <format=hex>;
uint32  SectionBOff  <format=hex>;
uint32  SectionCOff  <format=hex>;
uint32  Reserved;
uint32  Field_24;

local int sa_size = SectionBOff - SectionAOff;
local int sb_size = SectionCOff - SectionBOff;
local int sc_size = FileSize()  - SectionCOff;
local int sb_stride = (SectionBCount > 0) ? sb_size / SectionBCount : 0;

FSeek(SectionAOff);
byte SectionA[sa_size] <comment="Event routing tree (1 record)">;

FSeek(SectionBOff);
byte SectionB[sb_size] <comment="Event handler records (17 × 103B)">;

FSeek(SectionCOff);
byte SectionC[sc_size] <comment="Event ID table">;

Printf("=== AEM Summary ===\n");
Printf("Signature: 0x%06X\n", Signature);
Printf("Section A: 0x%X  %dB (1 routing tree)\n", SectionAOff, sa_size);
Printf("Section B: 0x%X  %d × %dB (%d handlers)\n",
       SectionBOff, SectionBCount, sb_stride, SectionBCount);
Printf("Section C: 0x%X  %dB (event IDs)\n", SectionCOff, sc_size);
