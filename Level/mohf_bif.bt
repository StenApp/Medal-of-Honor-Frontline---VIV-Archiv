//------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: mohf_bif.bt
//   Authors: Sten + Claude
//   Version: 0.1.0
//   Purpose: Medal of Honor Frontline - BIF Behavior Interface Functions
//  Category: Game
// File Mask: *.dat
//   History:
//     0.1.0  2026-05-27  Initial. Magic "BIF\0", 29 functions.
//
// BIF = Behavior Interface Functions. AI behavior script bindings.
// bsbifunc.dat maps AI behavior IDs to function names/handlers.
// Function names are partially encoded (XOR or byte-shifted).
// Fragments visible: "SayDialog", "CuriousAttack", "FallDown",
// "CoverPoint", "TurnToLook", "WalkMedium", "RunAnimation" etc.
//
// Format: "BIF\0" magic + uint32 count + variable-length records.
// Internal encoding of function names not fully reversed.
//------------------------------------------------

LittleEndian();
OutputPaneClear();

char    Magic[4] <comment="'BIF\\0'">;
uint32  FunctionCount;  // = 29

byte    FunctionData[FileSize()-8] <comment="29 behavior function records, names partially encoded">;

Printf("=== BIF Summary ===\n");
Printf("Magic: %s\n", Magic);
Printf("Functions: %d AI behavior interface functions\n", FunctionCount);
Printf("NOTE: Function names are byte-encoded, not plain ASCII.\n");
Printf("Known functions (decoded fragments):\n");
Printf("  SayDialog, CuriousAttack, FallDown, CoverPoint,\n");
Printf("  TurnToLook, WalkMedium, RunAnimation, StartDance,\n");
Printf("  MoveStart, AlertState, ProximityAttack\n");
